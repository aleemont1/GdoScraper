# Configurazione chiavi API per i modelli AI (Opzionale)
# I modelli servono per effettuare visual auditing sui volantini PDF (estrazione dati da immagini).
# Se non fornisci nessuna chiave, la pipeline utilizzerà solamente i parser di testo o fallback.

# API Key di Google (se vuoi usare Gemini) - Ottienila su https://aistudio.google.com/
GEMINI_API_KEY=""

# API Key di Anthropic (se vuoi usare Claude) - Ottienila su https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Scelta del modello Claude (rimuovi il commento da quello desiderato)
#CLAUDE_MODEL_NAME="claude-haiku-4-5"
CLAUDE_MODEL_NAME="claude-sonnet-4-6"
#CLAUDE_MODEL_NAME="claude-opus-4-8"

# -------------------------------------------------------------
# Storage Engine Config (Avanzato)
# Lascia sqlite per mantenere tutto in locale (raccomandato)
# -------------------------------------------------------------
DB_ENGINE="sqlite"

# Parametri opzionali se decidi di usare Supabase invece di sqlite
# SUPABASE_URL="https://il-tuo-id.supabase.co"
# SUPABASE_KEY="la-tua-chiave-api-supabase"
